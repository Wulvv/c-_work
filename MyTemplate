//把cin的存放到vector里,但是按回车输入并不会结束
vector<string> v;
string s;

while(cin >> s)
    v.push_back(s);


//先确定输入个数，按下回车输入结束，程序不会一直等待
int n;
cin >> n;

vector<string> strs(n);

for(int i = 0; i < n; i++){
    cin >> strs[i];
}



//从输入获取字符串
string s;
getline(cin,s);



/* 字符串统计类题目基本都是这个套路：

1 统计字符次数
2 再遍历字符串
3 找满足条件的字符

模板： */

int count[256]={0};

for(char c:s) count[c]++;

for(int i=0;i<s.size();i++)
    if(count[s[i]]==1)
        return i;